---
import { siteData } from '../data/site';
import SectionHeading from './ui/SectionHeading.astro';
import ChatMockup from './ui/ChatMockup.astro';

const { demos } = siteData;
---

<section id="demo" class="section overflow-hidden">
  <div class="shell">
    <div class="space-y-12">
      <div class="reveal" data-reveal>
        <SectionHeading
          eyebrow="Demo"
          title="Simulaciones visuales para entender como se veria ZivenAI en tu operacion"
          description="Sin capturas externas ni dependencias pesadas: todo esta construido en HTML y CSS para mantener el sitio liviano y coherente."
          align="center"
        />
      </div>

      <div class="grid gap-6 xl:grid-cols-3">
        {demos.map((demo, index) => (
          <article class="panel reveal rounded-[32px] p-5" data-reveal style={`transition-delay: ${index * 100}ms;`}>
            <div class="mb-4 flex items-center justify-between">
              <div>
                <span class="text-xs font-semibold uppercase tracking-[0.22em] text-accent">{demo.label}</span>
                <h3 class="mt-2 text-xl font-semibold">{demo.title}</h3>
              </div>
              <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-300">
                En vivo
              </span>
            </div>
            <ChatMockup title={demo.title} subtitle="Simulacion conversacional" messages={demo.messages} compact />
            <p class="mt-4 text-sm leading-7 text-slate-300">{demo.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
