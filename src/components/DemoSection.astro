---
import { siteData } from '../data/site';
import SectionHeading from './ui/SectionHeading.astro';
import ChatMockup from './ui/ChatMockup.astro';

const { demos } = siteData;
---

<section id="demo" class="section overflow-hidden">
  <div class="shell">
    <div class="space-y-12">
      <div class="reveal" data-reveal>
        <SectionHeading
          eyebrow="Simulaciones"
          title="Conversaciones que muestran cómo ZivenAI responde, captura y deriva"
          description="Las demos están construidas como interfaces conversacionales simples y claras para explicar el producto sin recurrir a capturas externas."
          align="center"
        />
      </div>

      <div class="grid gap-6 xl:grid-cols-3">
        {demos.map((demo, index) => (
          <article class="panel reveal rounded-[32px] p-5 hover:-translate-y-1 hover:border-white/15" data-reveal style={`transition-delay: ${index * 100}ms;`}>
            <div class="mb-4 flex items-center justify-between">
              <div>
                <span class="text-xs font-semibold uppercase tracking-[0.22em] text-accent">{demo.label}</span>
                <h3 class="mt-2 text-xl font-semibold">{demo.title}</h3>
              </div>
              <span class="status-chip">
                {demo.status}
              </span>
            </div>
            <ChatMockup
              title={demo.title}
              subtitle="Simulación conversacional"
              messages={demo.messages}
              compact
              statusLabel={demo.status}
            />
            <p class="mt-4 text-sm leading-7 text-slate-300">{demo.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
