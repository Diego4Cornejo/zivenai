---
import { siteData } from '../data/site';
import SectionHeading from './ui/SectionHeading.astro';

const { steps } = siteData;
---

<section class="section">
  <div class="shell">
    <div class="space-y-12">
      <div class="reveal" data-reveal>
        <SectionHeading
          eyebrow="Cómo Funciona"
          title="Tres pasos para pasar de respuestas manuales a una atención automatizada más ordenada"
          description="La implementación está pensada para que el cambio sea claro, guiado y útil desde el inicio."
          align="center"
        />
      </div>

      <div class="grid gap-5 lg:grid-cols-3">
        {steps.map((step, index) => (
          <article class="panel reveal rounded-[30px] p-7" data-reveal>
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-sky to-accent text-lg font-semibold text-slate-950">
              {index + 1}
            </span>
            <h3 class="mt-6 text-xl font-semibold">{step.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-300">{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
