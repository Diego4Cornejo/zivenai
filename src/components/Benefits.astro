---
import { siteData } from '../data/site';
import SectionHeading from './ui/SectionHeading.astro';

const { benefits, stats } = siteData;
---

<section class="section">
  <div class="shell">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="reveal" data-reveal>
        <SectionHeading
          eyebrow="Beneficios"
          title="Beneficios concretos para negocios que quieren atender mejor sin sumar más carga manual"
          description="La propuesta es simple: responder más rápido, capturar mejor cada oportunidad y dar una experiencia más profesional desde el primer mensaje."
        />
      </div>

      <div class="space-y-6">
        <div class="grid gap-5 sm:grid-cols-2">
          {benefits.map((item) => (
            <article class="panel reveal rounded-[28px] p-6" data-reveal>
              <h3 class="text-lg font-semibold">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-300">{item.description}</p>
            </article>
          ))}
        </div>
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          {stats.map((stat) => (
            <div class="panel reveal rounded-[24px] px-5 py-4" data-reveal>
              <p class="text-xs uppercase tracking-[0.22em] text-slate-400">{stat.label}</p>
              <p class="mt-2 text-xl font-semibold text-white">{stat.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
