---
import { siteData } from '../data/site';
import SectionHeading from './ui/SectionHeading.astro';
import Icon from './ui/Icon.astro';

const { useCases } = siteData;
---

<section id="solucion" class="section">
  <div class="shell">
    <div class="space-y-12">
      <div class="reveal" data-reveal>
        <SectionHeading
          eyebrow="Para quien es"
          title="Pensado para negocios que necesitan responder mejor sin sumar mas carga operativa"
          description="ZivenAI se adapta a rubros con alto volumen de consultas, reservas y oportunidades comerciales que no pueden esperar."
        />
      </div>

      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {useCases.map((item) => (
          <article class="panel reveal rounded-[28px] p-6" data-reveal>
            <div class="mb-5 inline-flex rounded-2xl border border-white/10 bg-white/5 p-3 text-accent">
              <Icon name={item.icon} />
            </div>
            <h3 class="text-xl font-semibold">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-300">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
