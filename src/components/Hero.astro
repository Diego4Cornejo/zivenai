---
import { siteData } from '../data/site';
import ButtonLink from './ui/ButtonLink.astro';
import ChatMockup from './ui/ChatMockup.astro';
import Icon from './ui/Icon.astro';

const { hero, ctaLinks } = siteData;
---

<section id="inicio" class="section overflow-hidden pt-36 sm:pt-40">
  <div class="glow-orb left-0 top-24 h-56 w-56 bg-sky/30"></div>
  <div class="glow-orb right-0 top-12 h-72 w-72 bg-accent/20"></div>
  <div class="shell">
    <div class="grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="space-y-8 reveal" data-reveal>
        <span class="eyebrow">{hero.badge}</span>
        <div class="space-y-6">
          <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-5xl lg:text-6xl">
            {hero.title}
          </h1>
          <p class="max-w-2xl text-lg leading-8 text-slate-300 sm:text-xl">
            {hero.description}
          </p>
        </div>

        <div class="flex flex-col gap-4 sm:flex-row">
          <ButtonLink href={ctaLinks.primary} label={hero.primaryCta} icon="arrow" />
          <ButtonLink href={ctaLinks.secondary} label={hero.secondaryCta} variant="secondary" />
        </div>

        <div class="grid gap-3 text-sm text-slate-300 sm:grid-cols-3">
          {hero.trustLabels.map((label) => (
            <div class="panel rounded-2xl px-4 py-3 text-center">{label}</div>
          ))}
        </div>

        <div class="flex flex-wrap gap-3">
          {hero.channelLabels.map((label) => (
            <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-200">
              {label}
            </span>
          ))}
        </div>
      </div>

      <div class="relative reveal lg:justify-self-end" data-reveal>
        <div class="absolute -left-6 top-10 hidden h-28 w-28 rounded-full border border-white/10 bg-white/5 blur-sm lg:block"></div>
        <div class="absolute -right-8 bottom-6 h-36 w-36 rounded-full bg-gradient-to-br from-blush/30 to-sky/10 blur-3xl"></div>
        <div class="relative mx-auto max-w-xl animate-float">
          <div class="absolute inset-x-8 -top-6 mx-auto h-12 rounded-full bg-accent/20 blur-2xl"></div>
          <div class="panel-strong relative overflow-hidden rounded-[36px] border-white/10 p-3">
            <div class="rounded-[28px] border border-white/10 bg-ink/90 p-3">
              <div class="mb-3 flex items-center justify-between rounded-[24px] border border-white/10 bg-white/5 px-4 py-3">
                <div>
                  <p class="text-sm font-semibold text-white">Asistente ZivenAI</p>
                  <p class="text-xs text-slate-400">WhatsApp y voz automatizados para atencion y ventas</p>
                </div>
                <span class="rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-accent">
                  Activo
                </span>
              </div>
              <ChatMockup title="Conversacion en tiempo real" subtitle="Flujo de ejemplo" messages={hero.heroMessages} />
            </div>
          </div>
          <div class="panel absolute -bottom-10 -left-4 hidden max-w-[270px] rounded-[24px] p-4 lg:block">
            <div class="flex items-start gap-3">
              <span class="inline-flex rounded-2xl border border-white/10 bg-white/5 p-3 text-accent">
                <Icon name="phone" />
              </span>
              <div>
                <p class="text-sm font-semibold text-white">{hero.voiceCallout.title}</p>
                <p class="mt-2 text-sm leading-6 text-slate-300">{hero.voiceCallout.description}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
