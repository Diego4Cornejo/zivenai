---
import { siteData } from '../data/site';
import SectionHeading from './ui/SectionHeading.astro';
import Icon from './ui/Icon.astro';

const { features } = siteData;
---

<section id="funciones" class="section">
  <div class="shell">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div class="reveal lg:sticky lg:top-28" data-reveal>
        <SectionHeading
          eyebrow="Funciones"
          title="Automatizacion util, clara y preparada para conversaciones reales"
          description="Cada funcionalidad busca resolver friccion operativa, mejorar atencion y convertir conversaciones en acciones concretas."
        />
      </div>

      <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
        {features.map((feature) => (
          <article class="panel reveal group rounded-[28px] p-6 hover:-translate-y-1 hover:border-white/15 hover:bg-white/[0.06]" data-reveal>
            <div class="mb-5 inline-flex rounded-2xl border border-white/10 bg-white/5 p-3 text-sky group-hover:text-accent">
              <Icon name={feature.icon} />
            </div>
            <h3 class="text-lg font-semibold text-white">{feature.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-300">{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
