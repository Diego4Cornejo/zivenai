---
type Message = {
  from: 'user' | 'assistant';
  text: string;
  time: string;
};

type Props = {
  title: string;
  subtitle: string;
  messages: Message[];
  compact?: boolean;
};

const { title, subtitle, messages, compact = false } = Astro.props as Props;
---

<div class:list={['panel-strong overflow-hidden', compact ? 'max-w-md' : 'max-w-xl', 'relative']}>
  <div class="absolute inset-x-0 top-0 h-24 bg-gradient-to-r from-sky/20 via-accent/10 to-blush/20 blur-2xl"></div>
  <div class="relative border-b border-white/10 bg-white/[0.03] px-5 py-4">
    <div class="flex items-center gap-3">
      <div class="flex gap-1.5">
        <span class="h-2.5 w-2.5 rounded-full bg-rose-400/80"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-amber-300/80"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-emerald-400/80"></span>
      </div>
      <div>
        <p class="text-sm font-semibold text-white">{title}</p>
        <p class="text-xs text-slate-400">{subtitle}</p>
      </div>
    </div>
  </div>
  <div class:list={['chat-scrollbar space-y-3 overflow-y-auto bg-gradient-to-b from-white/[0.03] to-transparent p-5', compact ? 'max-h-[420px]' : 'max-h-[520px]']}>
    {messages.map((message) => (
      <div class:list={['flex', message.from === 'user' ? 'justify-start' : 'justify-end']}>
        <div
          class:list={[
            'max-w-[86%] rounded-[24px] px-4 py-3 text-sm leading-6 shadow-lg',
            message.from === 'user'
              ? 'rounded-bl-md border border-white/10 bg-white/10 text-slate-100'
              : 'rounded-br-md bg-gradient-to-br from-accent/90 to-sky/80 text-slate-950'
          ]}
        >
          <p>{message.text}</p>
          <span
            class:list={[
              'mt-2 block text-[11px]',
              message.from === 'user' ? 'text-slate-400' : 'text-slate-900/70'
            ]}
          >
            {message.time}
          </span>
        </div>
      </div>
    ))}
  </div>
</div>
