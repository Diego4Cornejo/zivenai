---
import { siteData } from '../data/site';
import ButtonLink from './ui/ButtonLink.astro';
import Icon from './ui/Icon.astro';

const { brandName, navItems, ctaLinks } = siteData;
---

<header class="fixed inset-x-0 top-0 z-50 px-4 pt-4 sm:px-6">
  <div class="mx-auto max-w-7xl">
    <nav class="panel flex items-center justify-between rounded-full border-white/10 bg-slate-950/65 px-4 py-3 sm:px-6">
      <a href="#inicio" class="flex items-center gap-3 text-sm font-semibold tracking-[0.18em] text-white">
        <span class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-accent to-sky text-slate-950 shadow-lg shadow-accent/20">
          Z
        </span>
        <span>{brandName}</span>
      </a>

      <div class="hidden items-center gap-7 lg:flex">
        {navItems.map((item) => (
          <a href={item.href} class="text-sm text-slate-300 hover:text-white">
            {item.label}
          </a>
        ))}
      </div>

      <div class="hidden lg:block">
        <ButtonLink href={ctaLinks.primary} label="Solicitar demo" icon="arrow" />
      </div>

      <button
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-white lg:hidden"
        data-menu-toggle
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menu"
      >
        <Icon name="menu" />
      </button>
    </nav>

    <div
      id="mobile-menu"
      class="panel mt-3 hidden overflow-hidden rounded-[28px] px-5 py-5 lg:hidden"
      data-mobile-menu
    >
      <div class="flex flex-col gap-4">
        {navItems.map((item) => (
          <a href={item.href} class="rounded-2xl border border-transparent px-4 py-3 text-sm text-slate-200 hover:border-white/10 hover:bg-white/5">
            {item.label}
          </a>
        ))}
        <ButtonLink href={ctaLinks.primary} label="Solicitar demo" icon="arrow" className="mt-2 w-full" />
      </div>
    </div>
  </div>
</header>

<script>
  const toggleButton = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');

  if (toggleButton instanceof HTMLButtonElement && menu instanceof HTMLElement) {
    const closeMenu = () => {
      menu.classList.add('hidden');
      toggleButton.setAttribute('aria-expanded', 'false');
    };

    toggleButton.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      toggleButton.setAttribute('aria-expanded', String(!isOpen));
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }
</script>
