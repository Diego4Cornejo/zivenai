---
import { siteData } from '../data/site';
import SectionHeading from './ui/SectionHeading.astro';
import Icon from './ui/Icon.astro';

const { trust } = siteData;
---

<section class="section">
  <div class="shell">
    <div class="space-y-12">
      <div class="reveal" data-reveal>
        <SectionHeading
          eyebrow="Confianza"
          title="Más claro para tu negocio, más confiable para tu equipo y tus clientes"
          description="Además de automatizar, ZivenAI busca reducir dudas: se personaliza, se implementa contigo y puede derivar conversaciones cuando hace falta una persona real."
          align="center"
        />
      </div>

      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {trust.map((item) => (
          <article class="panel reveal rounded-[30px] p-6 hover:-translate-y-1 hover:border-white/15 hover:bg-white/[0.05]" data-reveal>
            <div class="mb-5 inline-flex rounded-2xl border border-white/10 bg-white/5 p-3 text-accent">
              <Icon name={item.icon} />
            </div>
            <h3 class="text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-300">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
